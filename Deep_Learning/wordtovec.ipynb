    "import gensim.downloader as api\n",
    "\n",
    "# Load pretrained Word2Vec model (Google News)\n",
    "model = api.load(\"word2vec-google-news-300\")\n",
    "\n",
    "# Get vector of a word\n",
    "vector = model[\"God\"]\n",
    "\n",
    "print(vector)\n",
    "print(\"Dimension:\", vector.shape)"
